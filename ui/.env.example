# ─────────────────────────────────────────────────────────────────────────────
# Survival Island – local development environment
#
# 1. Copy this file:   cp ui/.env.example ui/.env.local
# 2. Fill in your values below
# 3. Run:              cd ui && npm run dev
#
# NEVER commit .env.local  (it is already listed in .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Your HuggingFace API token (read-only scope is sufficient)
# Create one at: https://huggingface.co/settings/tokens
VITE_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The instruct model used for the survival agent.
# Must support the Mistral [INST] prompt format.
#
# Recommended (free-tier Inference API):
#   mistralai/Mistral-7B-Instruct-v0.2
#   HuggingFaceH4/zephyr-7b-beta
#
# Requires license acceptance on HuggingFace.co:
#   meta-llama/Llama-3.1-8B-Instruct
VITE_HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
